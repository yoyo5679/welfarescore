# 이 파일은 .env.example 입니다 (GitHub에 올려도 되는 템플릿)
# 실제 값은 .env 파일에 작성하고 .gitignore에 추가하세요

# 공공데이터포털 API Key (복지로, 행정안전부, 사회보장정보원 공통)
PUBLIC_DATA_API_KEY=여기에_실제_키_입력

# 온통청년 API Keys (3개 로테이션)
YOUTH_CENTER_API_KEY_1=여기에_실제_키_입력
YOUTH_CENTER_API_KEY_2=여기에_실제_키_입력
YOUTH_CENTER_API_KEY_3=여기에_실제_키_입력

# 카카오맵 App Key
KAKAO_MAP_APP_KEY=여기에_실제_키_입력
